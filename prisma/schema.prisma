generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  REELS          @map("reels")
  STORY          @map("story")
  TIKTOK         @map("tiktok")
  YOUTUBE_SHORTS @map("youtube_shorts")

  @@map("content_type")
}

enum ProjectStatus {
  DRAFT      @map("draft")
  PROCESSING @map("processing")
  READY      @map("ready")
  SCHEDULED  @map("scheduled")
  PUBLISHED  @map("published")
  ERROR      @map("error")

  @@map("project_status")
}

enum MediaFileType {
  IMAGE    @map("image")
  AUDIO    @map("audio")
  SUBTITLE @map("subtitle")
  VIDEO    @map("video")

  @@map("media_file_type")
}

enum GeneratedVideoStatus {
  PROCESSING @map("processing")
  READY      @map("ready")
  ERROR      @map("error")

  @@map("generated_video_status")
}

enum SocialPlatform {
  INSTAGRAM      @map("instagram")
  TIKTOK         @map("tiktok")
  YOUTUBE        @map("youtube")
  YOUTUBE_SHORTS @map("youtube_shorts")

  @@map("social_platform")
}

enum ScheduledPostStatus {
  SCHEDULED @map("scheduled")
  PUBLISHED @map("published")
  FAILED    @map("failed")
  CANCELED  @map("canceled")

  @@map("scheduled_post_status")
}

enum AssetProvider {
  MANUS
  GEMINI

  @@map("asset_provider")
}

enum AssetGenerationStatus {
  QUEUED
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
  MANUAL_ACTION_REQUIRED

  @@map("asset_generation_status")
}

enum JobName {
  AI_ASSET_GENERATION
  VIDEO_RENDER
  SCHEDULE_PUBLISH

  @@map("job_name")
}

enum JobRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED

  @@map("job_run_status")
}

model User {
  id             String           @id @default(cuid())
  name           String?
  email          String           @unique
  passwordHash   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  projects       ContentProject[]
  manusSettings  ManusSettings?
  socialAccounts SocialAccount[]
  jobRuns        JobRun[]

  @@map("users")
}

model ContentProject {
  id                  String               @id @default(cuid())
  userId              String?
  title               String
  prompt              String
  caption             String?
  contentType         ContentType
  status              ProjectStatus        @default(DRAFT)
  errorMessage        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  mediaFiles          MediaFile[]
  generatedVideos     GeneratedVideo[]
  scheduledPosts      ScheduledPost[]
  assetGenerationRuns AssetGenerationRun[]
  jobRuns             JobRun[]

  @@index([userId])
  @@index([contentType])
  @@index([status])
  @@index([createdAt])
  @@map("content_projects")
}

model MediaFile {
  id           String         @id @default(cuid())
  projectId    String
  type         MediaFileType
  path         String
  originalName String
  size         Int
  format       String
  mimeType     String?
  createdAt    DateTime       @default(now())
  project      ContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([type])
  @@map("media_files")
}

model GeneratedVideo {
  id         String               @id @default(cuid())
  projectId  String
  path       String
  duration   Int?
  resolution String
  status     GeneratedVideoStatus @default(PROCESSING)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  project    ContentProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@map("generated_videos")
}

model ScheduledPost {
  id          String              @id @default(cuid())
  projectId   String
  socialAccountId String?
  platform    SocialPlatform
  scheduledAt DateTime
  caption     String
  visibility  String?
  providerPostId String?
  providerStatus String?
  publishErrorCode String?
  publishErrorMessage String?
  publishAttemptedAt DateTime?
  publishedAt DateTime?
  status      ScheduledPostStatus @default(SCHEDULED)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  project     ContentProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount?    @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  jobRuns     JobRun[]

  @@index([projectId])
  @@index([socialAccountId])
  @@index([platform])
  @@index([scheduledAt])
  @@index([status])
  @@map("scheduled_posts")
}

model SocialAccount {
  id             String         @id @default(cuid())
  userId         String
  platform       SocialPlatform
  accountName    String
  externalId     String?
  accessTokenRef String?
  providerAccountType String?
  accessTokenCiphertext String?
  refreshTokenCiphertext String?
  tokenExpiresAt DateTime?
  scopes       Json?
  status       String         @default("active")
  reauthRequired Boolean      @default(false)
  tokenErrorMessage String?
  lastValidatedAt DateTime?
  providerMetadata Json?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledPosts ScheduledPost[]

  @@unique([userId, platform, accountName])
  @@index([externalId])
  @@index([userId])
  @@index([platform])
  @@map("social_accounts")
}

model ManusSettings {
  id                   String   @id @default(cuid())
  userId               String?
  apiKey               String?
  modelPreference      String?
  promptPreference     String?
  defaultReelsConfig   Json
  defaultStoriesConfig Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([userId])
  @@map("manus_settings")
}

model AssetGenerationRun {
  id             String                @id @default(cuid())
  projectId      String
  provider       AssetProvider
  providerTaskId String?
  status         AssetGenerationStatus @default(QUEUED)
  summary        Json?
  missingAssets  Json?
  startedAt      DateTime              @default(now())
  finishedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  project        ContentProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([provider])
  @@index([status])
  @@index([createdAt])
  @@index([providerTaskId])
  @@map("asset_generation_runs")
}

model JobRun {
  id              String        @id @default(cuid())
  name            JobName
  status          JobRunStatus  @default(QUEUED)
  userId          String?
  projectId       String?
  scheduledPostId String?
  bullJobId       String?
  payload         Json
  attemptsMade    Int           @default(0)
  attemptsAllowed Int           @default(3)
  errorCode       String?
  errorMessage    String?
  queuedAt        DateTime      @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  project         ContentProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  scheduledPost   ScheduledPost? @relation(fields: [scheduledPostId], references: [id], onDelete: SetNull)
  logs            JobRunLog[]

  @@index([userId, status])
  @@index([projectId, status])
  @@index([scheduledPostId, status])
  @@index([bullJobId])
  @@index([createdAt])
  @@map("job_runs")
}

model JobRunLog {
  id        String   @id @default(cuid())
  jobRunId  String
  level     String   @default("info")
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  jobRun    JobRun   @relation(fields: [jobRunId], references: [id], onDelete: Cascade)

  @@index([jobRunId])
  @@index([createdAt])
  @@map("job_run_logs")
}
