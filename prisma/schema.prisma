generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentStatus {
  DRAFT
  READY
  FAILED
  SCHEDULED
  PUBLISHED
}

enum AssetType {
  IMAGE
  AUDIO
  VIDEO
}

model Content {
  id           String        @id @default(cuid())
  title        String
  caption      String
  status       ContentStatus @default(DRAFT)
  videoPath    String?
  errorMessage String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  assets       Asset[]

  @@index([status])
  @@index([createdAt])
}

model Asset {
  id        String    @id @default(cuid())
  contentId String
  type      AssetType
  fileName  String
  mimeType  String
  path      String
  size      Int
  createdAt DateTime  @default(now())
  content   Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([type])
}
